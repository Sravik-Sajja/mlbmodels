{
    "version": 2,
    "builds": [
      { "src": "api/predict.py",  "use": "@vercel/python" },
      { "src": "frontend/**",     "use": "@vercel/static" }
    ],
    "routes": [
      { "src": "/api/predict",    "dest": "/api/predict.py" },
      { "src": "/(.*)",           "dest": "/frontend/$1" }
    ]
  }